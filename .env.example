# Server port inside the container
PORT=3000

# Max upload file size in bytes (default 100 MB)
MAX_FILE_SIZE=104857600

# Admin panel password (leave empty to disable admin)
ADMIN_PASSWORD=

# JWT secret — MUST be changed in production (min 32 random chars)
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Paths (defaults work inside Docker, change for local dev)
# UPLOADS_DIR=/app/uploads
# DB_PATH=/app/data/discord-clone.db
