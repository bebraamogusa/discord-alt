{
  "productName": "Discord Alt",
  "version": "1.0.0",
  "identifier": "com.discord-alt.app",
  "build": {
    "frontendDist": "https://lolihentai.online"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Discord Alt",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "userAgent": "Discord Alt/1.0 (Tauri)"
      }
    ],
    "security": {
      "csp": "default-src 'self' https://lolihentai.online; script-src 'self' 'unsafe-inline' https://cdn.socket.io https://lolihentai.online; style-src 'self' 'unsafe-inline' https://lolihentai.online; connect-src 'self' ws: wss: http: https: tauri: ipc:; img-src 'self' http: https: data: blob:; media-src 'self' blob: mediastream:; font-src 'self' data:",
      "dangerousRemoteDomainIpcAccess": [
        {
          "scheme": "https",
          "domain": "lolihentai.online",
          "windows": ["main"],
          "plugins": ["notification"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
